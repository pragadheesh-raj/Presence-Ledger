<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="https://glitch.com/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Modify Employee</title>

    <link rel="canonical" href="#">
    <meta name="description" content="Modify employee details in the attendance system.">
    <meta property="og:title" content="Modify Employee">
    <meta property="og:type" content="article">
    <meta property="og:url" content="#">
    <meta property="og:description" content="Modify employee details in the system.">
    <meta name="twitter:card" content="summary">

    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <div class="wrapper">
      <div class="content" role="main">

        <div class="color-form">
          <h1>Modify Employee</h1>
          <p>Enter an employee code to view and update employee details.</p>

          {{#if error}}
            <p style="color: red;"><strong>Error:</strong> {{error}}</p>
          {{/if}}

          {{#if success}}
            <p style="color: green;"><strong>Success:</strong> {{success}}</p>
          {{/if}}

          <form action="/find-employee" method="POST">
            <label for="e_code">Employee Code:</label><br>
            <input type="text" name="e_code" id="e_code" value="{{e_code}}" required><br><br>

            <button type="submit">Find Employee</button>
          </form>

          {{#if found}}
            <hr style="margin: 20px 0;">

            <form action="/modify-employee" method="POST">
              <input type="hidden" name="e_code" value="{{e_code}}">

              <label for="employee_code_display">Employee Code:</label><br>
              <input
                type="text"
                id="employee_code_display"
                value="{{e_code}}"
                readonly
              ><br><br>

              <label for="current_name">Current Employee Name:</label><br>
              <input
                type="text"
                id="current_name"
                value="{{current_name}}"
                readonly
              ><br><br>

              <label for="new_name">New Employee Name:</label><br>
              <input
                type="text"
                name="new_name"
                id="new_name"
                value="{{current_name}}"
                required
              ><br><br>

              <label for="g">Gender:</label><br>
              <select
                style="padding: 15px; border-radius: 40px"
                name="g"
                id="g"
                required
              >
                <option value="">Select Gender</option>
                <option value="MALE" {{#if isMale}}selected{{/if}}>Male</option>
                <option value="FEMALE" {{#if isFemale}}selected{{/if}}>Female</option>
              </select><br><br>

              <button type="submit">Update Employee</button>
            </form>
          {{/if}}
        </div>

        <div style="margin-top: 20px;">
          <button style="border-radius: 40px;">
            <a href="/" style="text-decoration: none; color: inherit;">🏠 Back to Home</a>
          </button>
        </div>

        <div class="instructions">
          <h2></h2>
          <p></p>
        </div>

      </div>
    </div>

    <footer class="footer">
      <div class="links"></div>
    </footer>
  </body>
</html>