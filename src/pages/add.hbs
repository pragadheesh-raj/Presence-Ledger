<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="https://glitch.com/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Add New Employee</title>

    <!-- Meta tags for SEO -->
    <link rel="canonical" href="#">
    <meta name="description" content="Add a new employee to the attendance system.">
    <meta property="og:title" content="Add Employee">
    <meta property="og:type" content="article">
    <meta property="og:url" content="#">
    <meta property="og:description" content="Add a new employee to the system.">
    <meta name="twitter:card" content="summary">

    <!-- Stylesheet -->
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <div class="wrapper">
      <div class="content" role="main">

        <div class="color-form">
          <h1>Add New Employee</h1>
          <p>Please fill in the details below to add an employee.</p>

          {{#if error}}
            <p style="color: red;"><strong>Error:</strong> {{error}}</p>
          {{/if}}

          {{#if success}}
            <p style="color: green;"><strong>Success:</strong> {{success}}</p>
          {{/if}}

          <form action="/add-employee" method="POST">
            <label for="e_code">Employee Code:</label><br>
            <input type="text" name="e_code" id="e_code" required><br><br>

            <label for="e_name">Employee Name:</label><br>
            <input type="text" name="e_name" id="e_name" required><br><br>

            <label for="g">Gender:</label><br>
            <select style="padding: 15px; border-radius: 40px" name="g" id="g" required>
              <option value="">Select Gender</option>
              <option value="MALE">Male</option>
              <option value="FEMALE">Female</option>
            </select><br><br>

            <button type="submit"> Add </button>
          </form>
        </div>

        <div style="margin-top: 20px;">
          <button style="border-radius: 40px;">
            <a href="/" style="text-decoration: none; color: inherit;">🏠 Back to Home</a>
          </button>
        </div>
        
        <div class="instructions">
          <h2></h2>
          <p></p>
        </div>

      </div>
    </div>

    <footer class="footer">
      <div class="links"></div>
    </footer>
  </body>
</html>
